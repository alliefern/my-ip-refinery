# ── App ──────────────────────────────────────────────────────────────
# Public URL of the deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://myiprefinery.com
# Brand name shown across the UI. Branding is configuration, not code.
NEXT_PUBLIC_BRAND_NAME=My IP Refinery

# ── Demo mode ────────────────────────────────────────────────────────
# "true" runs the entire app against a seeded in-memory demo project:
# no Supabase, no OpenAI, no worker required. Set to "false" once the
# real credentials below are configured.
DEMO_MODE=true

# ── Supabase ─────────────────────────────────────────────────────────
# Project settings → API. The service role key is server-only: never
# expose it to the browser and never commit it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ───────────────────────────────────────────────────────────
# Server-only. Model names are env-configurable so they can be changed
# without a deployment.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# ── Background worker ────────────────────────────────────────────────
# Shared secret the worker uses to authenticate against the app's
# internal job endpoints. Generate with: openssl rand -hex 32
BACKGROUND_WORKER_SECRET=

# ── Limits (commercial protection) ───────────────────────────────────
MAX_FILES_PER_PROJECT=10
MAX_FILE_BYTES=4294967296
MAX_TOTAL_DURATION_MINUTES=720
MAX_ACTIVE_PROJECTS_PER_USER=3
MAX_REGENERATIONS_PER_LESSON=5
